---
const { lang = "es" } = Astro.props;

const translations = {
  es: {
    title: "Lo que dicen nuestros clientes",
    reviews: [
      {
        text: "Excelente servicio de administración para mi apartamento en Tenerife Sur. Se encargan de todo y han maximizado los ingresos de mi vivienda vacacional.",
        author: "Carlos M.",
        nationality: "ES",
        rating: 5,
      },
      {
        text: "Como propietario extranjero, contar con un administrador de confianza en Tenerife es fundamental. Su equipo es profesional y siempre responde rápidamente.",
        author: "Ana P.",
        nationality: "ES",
        rating: 5,
      },
    ],
  },
  en: {
    title: "What our clients say",
    reviews: [
      {
        text: "Excellent management service for my apartment in South Tenerife. They take care of everything and have maximized my vacation rental income.",
        author: "Richard T.",
        nationality: "UK",
        rating: 5,
      },
      {
        text: "As a foreign owner, having a trustworthy property manager in Tenerife is essential. Their team is professional and always responds quickly.",
        author: "Sarah L.",
        nationality: "UK",
        rating: 5,
      },
    ],
  },
  de: {
    title: "Was unsere Kunden sagen",
    reviews: [
      {
        text: "Ausgezeichneter Verwaltungsservice für meine Wohnung im Süden Teneriffas. Sie kümmern sich um alles und haben meine Einnahmen aus der Ferienvermietung maximiert.",
        author: "Michael S.",
        nationality: "DE",
        rating: 5,
      },
      {
        text: "Als ausländischer Eigentümer ist es wichtig, einen vertrauenswürdigen gemeinschaft verwalter auf Teneriffa zu haben. Ihr Team ist professionell und reagiert immer schnell.",
        author: "Brigitte K.",
        nationality: "DE",
        rating: 5,
      },
    ],
  },
};

const content = translations[lang] || translations.es;
---

<section class="mb-12 max-w-6xl mx-auto px-4" aria-labelledby="testimonials-heading">
  <div class="text-center mb-10">
    <h2
      id="testimonials-heading"
      class="text-3xl font-extrabold leading-tight tracking-tight text-brand-blueFinca sm:text-4xl"
    >
      {content.title}
    </h2>
    <div class="w-16 h-1 bg-brand-greenFinca mx-auto mt-4 rounded-full"></div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    {
      content.reviews.map((review: any) => (
        <div
          class="relative bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-100 group"
          itemscope
          itemtype="https://schema.org/Review"
        >
          <!-- Top accent bar -->
          <div class="h-1 w-full bg-gradient-to-r from-brand-blueFinca to-brand-greenFinca" />

          <div class="p-6 pt-5">
            <!-- Quote mark decorative -->
            <svg
              class="w-8 h-8 text-brand-blueFinca/20 mb-3"
              fill="currentColor"
              viewBox="0 0 32 32"
              aria-hidden="true"
            >
              <path d="M10 8C6.686 8 4 10.686 4 14v10h10V14H7c0-1.654 1.346-3 3-3V8zm18 0c-3.314 0-6 2.686-6 6v10h10V14h-7c0-1.654 1.346-3 3-3V8z" />
            </svg>

            <!-- Stars -->
            <div
              itemprop="reviewRating"
              itemscope
              itemtype="https://schema.org/Rating"
            >
              <meta itemprop="worstRating" content="1" />
              <meta itemprop="bestRating" content="5" />
              <meta itemprop="ratingValue" content={review.rating.toString()} />
              <div
                class="flex gap-0.5 mb-4"
                aria-label={`${review.rating} de 5 estrellas`}
              >
                {Array.from({ length: review.rating }).map(() => (
                  <svg
                    class="w-4 h-4 text-amber-400 fill-current"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>

            <!-- Review text -->
            <blockquote
              itemprop="reviewBody"
              class="text-gray-700 leading-relaxed text-sm sm:text-base mb-5 italic"
            >
              "{review.text}"
            </blockquote>

            <!-- Author -->
            <footer class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-blueFinca to-brand-greenFinca flex items-center justify-center flex-shrink-0">
                <span class="text-white text-xs font-bold">
                  {review.author.charAt(0)}
                </span>
              </div>
              <div
                itemprop="author"
                itemscope
                itemtype="https://schema.org/Person"
              >
                <span itemprop="name" class="font-semibold text-gray-900 text-sm">
                  {review.author}
                </span>
                <meta itemprop="nationality" content={review.nationality} />
              </div>
            </footer>
          </div>

          <meta itemprop="datePublished" content="2023-10-15" />
          <div
            itemprop="itemReviewed"
            itemscope
            itemtype="https://schema.org/Service"
          >
            <meta itemprop="name" content="GestoFinca Property Management" />
            <meta itemprop="serviceType" content="Property Management" />
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .transition-all {
      transition: none;
    }
  }
</style>

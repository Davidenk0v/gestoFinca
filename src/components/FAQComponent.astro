---
const { lang, faq } = Astro.props;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.questions.map((q: any) => ({
    "@type": "Question",
    name: q.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: q.answer,
    },
  })),
};
---

<section
  class="mb-12 max-w-3xl mx-auto"
  itemscope
  itemtype="https://schema.org/FAQPage"
  role="region"
  aria-labelledby="faq-title"
>
  <div class="text-center mb-10">
    <span
      class="inline-block text-orange-500 font-semibold text-xs tracking-widest uppercase mb-3"
      >FAQ</span
    >
    <h2
      id="faq-title"
      class="text-3xl font-extrabold leading-tight tracking-tight text-brand-blueFinca sm:text-4xl"
    >
      {faq.title}
    </h2>
    <div class="w-16 h-1 bg-brand-greenFinca mx-auto mt-4 rounded-full"></div>
  </div>

  <div class="space-y-3">
    {
      faq.questions.map((item: any, index: number) => (
        <details
          class="faq-item group bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden transition-shadow duration-200 hover:shadow-md"
          itemscope
          itemprop="mainEntity"
          itemtype="https://schema.org/Question"
        >
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none hover:bg-gray-50/80 transition-colors duration-200 gap-3">
            <div class="flex items-center gap-4 min-w-0">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-blueFinca/10 text-brand-blueFinca text-xs font-bold flex items-center justify-center">
                {index + 1}
              </span>
              <h3
                itemprop="name"
                class="font-semibold text-gray-800 text-sm sm:text-base leading-snug"
              >
                {item.question}
              </h3>
            </div>
            <svg
              class="flex-shrink-0 w-5 h-5 text-brand-blueFinca transition-transform duration-300 group-open:rotate-180"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </summary>

          <div
            itemscope
            itemprop="acceptedAnswer"
            itemtype="https://schema.org/Answer"
            class="px-5 pb-5"
          >
            <div
              class="ml-11 pl-4 border-l-2 border-brand-greenFinca/50 text-gray-600 leading-relaxed text-sm sm:text-base"
              itemprop="text"
            >
              {item.answer}
            </div>
          </div>
        </details>
      ))
    }
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
  details > summary::marker {
    content: "";
  }
  details[open] {
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.07),
      0 2px 4px -2px rgb(0 0 0 / 0.07);
  }
</style>

---
import Image from "astro/components/Image.astro"
const { image, text, title, imageAlt } = Astro.props
---

<article class="group flex flex-col items-center text-center p-6 rounded-2xl bg-white/60 hover:bg-white hover:shadow-md transition-all duration-300 border border-transparent hover:border-gray-100">
  <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-brand-blueFinca/10 flex items-center justify-center mb-5 group-hover:bg-brand-blueFinca/15 transition-colors duration-300" aria-hidden="true">
    <Image
      src={image}
      alt={imageAlt || ""}
      width={56}
      height={56}
      loading="lazy"
      class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 group-hover:scale-110"
    />
  </div>
  <h3 class="text-xl font-bold leading-tight text-gray-900 mb-3">
    {title}
  </h3>
  <p class="text-base text-gray-600 leading-relaxed">
    {text}
  </p>
</article>

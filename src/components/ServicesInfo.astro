---
import CardService from "./CardService.astro";
import Vacation from "../assets/icons/bags.svg";
import House from "../assets/icons/buildings.svg";
import Car from "../assets/icons/car-services.svg";

const data = Astro.props.data;

const {
  property_management,
  vacation_rentals,
  vehicle_procedures,
  footer,
  services,
} = data;
---

<section
  class="bg-slate-100 flex flex-col gap-8 justify-center items-center px-4 py-14 sm:py-16"
  aria-labelledby="services-title"
>
  <div class="text-center max-w-2xl">
    <span class="inline-block text-orange-500 font-semibold text-sm tracking-widest uppercase mb-3">
      {services.title}
    </span>
    <h2
      id="services-title"
      class="text-4xl font-extrabold tracking-tight leading-tight text-gray-900 md:text-5xl"
    >
      {services.description}
    </h2>
    <div class="w-16 h-1 bg-brand-greenFinca mx-auto mt-5 rounded-full"></div>
  </div>

  <div
    class="flex flex-col md:flex-row gap-6 justify-center w-full max-w-screen-lg"
  >
    <!-- Primer CardService -->
    <div class="card-service flex-1">
      <CardService
        link={footer.pages.links[1].link}
        button={property_management.buttons.learn_more}
        text={property_management.description}
        title={property_management.title}
        img={House}
        alt="Imagen representativa de gestión de propiedades"
        id="property-management"
      />
    </div>

    <!-- Segundo CardService -->
    <div class="card-service flex-1">
      <CardService
        link={footer.pages.links[2].link}
        button={vacation_rentals.buttons.learn_more}
        text={vacation_rentals.description}
        title={vacation_rentals.title}
        img={Vacation}
        alt="Imagen representativa de alquileres vacacionales"
        id="vacation-rentals"
      />
    </div>

    <!-- Tercer CardService -->
    <div class="card-service flex-1">
      <CardService
        link={footer.pages.links[3].link}
        button={vehicle_procedures.buttons.learn_more}
        text={vehicle_procedures.description}
        title={vehicle_procedures.title}
        img={Car}
        alt="Imagen representativa de trámites vehiculares"
        id="vehicle-procedures"
      />
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(40px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animaciones con preferencias de movimiento reducido */
  @media (prefers-reduced-motion: no-preference) {
    section {
      animation: fadeIn 1s ease-out forwards;
    }

    section > div {
      animation: fadeInUp 1s ease-out forwards;
    }
  }
</style>

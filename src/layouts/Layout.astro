---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.jsx";
import WhatsAppIcon from "../components/WhatsappIcon.jsx";
import { loadTranslations } from "../utils/i18n";
import Footer from "../components/Footer.astro";
import logo from "../assets/logos/gestofinca.png";

const lang = Astro.params.lang;
const translations = await loadTranslations(lang);
const { title, description, noindex = false } = Astro.props;

const SITE_URL = "https://gestofinca.com";

const companyInfo = {
  name: "GestoFinca",
  logo: logo.src,
  siteUrl: SITE_URL,
};

const currentPath = Astro.url.pathname;
const canonicalUrl = `${SITE_URL}${currentPath}`;
const now = new Date().toISOString();
const ogImageUrl = new URL(logo.src, Astro.url).toString();

// Schema.org para la organización
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: companyInfo.name,
  image: ogImageUrl,
  logo: ogImageUrl,
  url: SITE_URL,
  telephone: "+34 689 95 89 31",
  email: "contact@gestofinca.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Adeje",
    addressLocality: "Santa Cruz de Tenerife",
    postalCode: "38670",
    addressRegion: "Islas Canarias",
    addressCountry: "ES",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: "28.2916",
    longitude: "-16.6291",
  },
  areaServed: {
    "@type": "Place",
    name: "Tenerife, Islas Canarias",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "18:00",
    },
  ],
  priceRange: "€€",
  availableLanguage: ["es", "en", "de"],
};

// Schema.org para la página web
const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  headline: title || translations.seo.title,
  description: description || translations.seo.description,
  url: canonicalUrl,
  inLanguage: lang,
  datePublished: "2024-03-15",
  dateModified: now,
  isPartOf: {
    "@type": "WebSite",
    name: companyInfo.name,
    url: SITE_URL,
  },
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: ogImageUrl,
  },
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", "h2", ".speakable"],
  },
};

const langMappings = {
  es: "es-ES",
  en: "en-GB",
  de: "de-DE",
};

const pathWithoutLang = currentPath.replace(new RegExp(`^/${lang}/`), "/");
const isHomepage = pathWithoutLang === "/" || pathWithoutLang === "";

const alternateUrls = ["es", "en", "de"].map((langCode) => {
  if (isHomepage) {
    return {
      lang: langMappings[langCode] || langCode,
      url: `${SITE_URL}/${langCode}/`,
    };
  }
  return {
    lang: langMappings[langCode] || langCode,
    url: `${SITE_URL}/${langCode}${pathWithoutLang}`,
  };
});

// BreadcrumbList para páginas internas
const breadcrumbSchema = !isHomepage
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name:
            lang === "es" ? "Inicio" : lang === "en" ? "Home" : "Startseite",
          item: `${SITE_URL}/${lang}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: title || translations.seo.title,
          item: canonicalUrl,
        },
      ],
    }
  : null;

const ogImageAlt =
  lang === "es"
    ? "GestoFinca - Administración de Fincas en Tenerife"
    : lang === "en"
      ? "GestoFinca - Property Management in Tenerife"
      : "GestoFinca - Hausverwaltung auf Teneriffa";

const seoKeywords = {
  es: "gestión de alquiler vacacional Tenerife, administración de fincas en Tenerife, gestión inmobiliaria en Canarias, empresa de gestión de propiedades, administrador de fincas cerca de mi, alquiler turístico Tenerife, gestión de comunidades de vecinos, trámites de vehículos Tenerife, cambio de titularidad de coche, transferencia de vehículos, matriculación de vehículos, baja de vehículos, gestoría de tráfico en Tenerife",
  en: "vacation rental management Tenerife, property management company Canary Islands, real estate services Tenerife, holiday rentals administration, property administration in Tenerife, community management services, vehicle paperwork Tenerife, car ownership transfer, vehicle registration services, car deregistration, traffic paperwork agency Tenerife",
  de: "Ferienvermietung Verwaltung Teneriffa, gemeinschaft verwaltung auf den Kanarischen Inseln, Hausverwaltung Teneriffa, Verwaltung von Ferienwohnungen, Immobilienmanagement Firma Teneriffa, Gemeinschaftsverwaltung Dienstleistungen, Fahrzeugzulassung Teneriffa, Kfz-Ummeldung, Fahrzeugübertragung, Abmeldung von Fahrzeugen, Verkehrsbehörde Dienstleistungen Teneriffa",
}[lang];
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />

    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <link rel="canonical" href={canonicalUrl} />
    {
      alternateUrls.map((alt) => (
        <link rel="alternate" hreflang={alt.lang} href={alt.url} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={`${SITE_URL}/es${isHomepage ? "/" : pathWithoutLang}`}
    />

    <title>
      {title || "Administración de Fincas en Tenerife"} | {companyInfo.name}
    </title>
    <meta
      name="description"
      content={description || translations.seo.description}
    />
    <meta name="keywords" content={seoKeywords} />

    <meta
      name="robots"
      content={noindex
        ? "noindex, follow"
        : "index, follow, max-image-preview:large"}
    />
    <meta name="author" content={companyInfo.name} />
    <meta name="geo.region" content="ES-CN" />
    <meta name="geo.placename" content="Tenerife" />
    <meta name="geo.position" content="28.2916;-16.6291" />
    <meta name="ICBM" content="28.2916, -16.6291" />

    <!-- Open Graph meta tags -->
    <meta property="og:title" content={title || translations.seo.title} />
    <meta
      property="og:description"
      content={description || translations.seo.description}
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(logo.width)} />
    <meta property="og:image:height" content={String(logo.height)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={langMappings[lang] || lang} />
    {
      Object.entries(langMappings)
        .filter(([l]) => l !== lang)
        .map(([, locale]) => (
          <meta property="og:locale:alternate" content={locale} />
        ))
    }
    <meta property="og:site_name" content={companyInfo.name} />

    <!-- Twitter Card meta tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title || translations.seo.title} />
    <meta
      name="twitter:description"
      content={description || translations.seo.description}
    />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- JSON-LD structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(webpageSchema)}
    />
    {
      breadcrumbSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbSchema)}
        />
      )
    }

    <!-- Google tag (gtag.js) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-17350177254"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "AW-17350177254");
    </script>

    <link rel="preload" href={logo.src} as="image" />

    <ClientRouter />
  </head>
  <body>
    <div class="flex flex-col min-h-screen bg-slate-100">
      <div>
        <Header
          client:load
          transition:persist
          lang={lang}
          data={translations}
        />
      </div>

      <a
        href="#main-content"
        class="sr-only focus:not-sr-only focus:absolute focus:p-4 focus:bg-white focus:z-50"
      >
        {
          lang === "es"
            ? "Saltar al contenido principal"
            : lang === "en"
              ? "Skip to main content"
              : "Zum Hauptinhalt springen"
        }
      </a>

      <main id="main-content" class="flex-grow">
        <slot />
      </main>

      <WhatsAppIcon transition:persist client:load />
      <Footer transition:persist texts={translations.footer} lang={lang} />
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    scroll-behavior: smooth;
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Outfit", sans-serif;
  }
</style>
